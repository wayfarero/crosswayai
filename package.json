{
    "name": "crosswayai",
    "displayName": "CrossWayAI",
    "description": "A VS Code extension that visualizes code dependencies for Progress OpenEdge ABL projects, to help developers understand project structure, navigate relationships between files and modules, and identify coupling and architectural issues. Visualize file, module, and symbol dependencies in VS Code with AI-assisted analysis. The extension uses AI to generate and update interactive dependency graphs, enabling faster code comprehension, refactoring, and architectural insights.",
    "version": "1.6.2",
    "publisher": "wayfare",
    "icon": "resources/CrossWayAI.png",
    "homepage": "https://github.com/wayfarero/crosswayai/blob/main/README.md",
    "repository": "https://github.com/wayfarero/crosswayai",
    "bugs": {
		"url": "https://github.com/wayfarero/crosswayai/issues"
	},
    "license": "MIT",
	"licenses": [
		{
			"type": "MIT",
			"url": "https://github.com/wayfarero/crosswayai/blob/main/LICENSE"
		}
	],
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "AI", "Programming Languages", "Visualization", "Other", "Chat", "Language Packs"
   ],
   "keywords": [
		"4gl",
		"abl",
		"openedge",
		"progress",
        "code visualization",
        "graph",
        "code analysis", 
        "mermaid",
        "diagrams",
        "code map",
        "documentation",
        "software architecture",
        "design",
        "code review"
	],
    "main": "./js/extension.js",
        "activationEvents": [
            "onCommand:crosswayai.generateMap",
            "onCommand:crosswayai.generateImpactDiagram",
            "onCommand:crosswayai.generateIncludeDiagram",
            "onCommand:crosswayai.generateInterfaceDiagram",
            "onCommand:crosswayai.generateCallDiagram",
            "onCommand:crosswayai.generateInheritanceDiagram",
            "onCommand:crosswayai.openCrosswayAIViewer",
            "onCommand:crosswayai.dumpAllDBDefinitions",
            "onCommand:crosswayai.generateTableRelationsDiagram"
        ],
    "contributes": {
        "submenus": [
            {
                "id": "crosswayai.submenu",
                "label": "CrossWayAI"
            }
        ],
        "commands": [
            {
                "command": "crosswayai.generateMap",
                "title": "CrossWayAI: Generate Dependency Map"
            },
            {
                "command": "crosswayai.dumpAllDBDefinitions",
                "title": "CrossWayAI: Dump All DB Definitions"
            },
            {
                "command": "crosswayai.generateImpactDiagram",
                "title": "Impact Diagram"
            },
            {
                "command": "crosswayai.generateIncludeDiagram",
                "title": "Include Diagram"
            },
            {
                "command": "crosswayai.generateInterfaceDiagram",
                "title": "Interface Diagram"
            },
            {
                "command": "crosswayai.generateCallDiagram",
                "title": "Call Diagram"
            },
            {
                "command": "crosswayai.generateInheritanceDiagram",
                "title": "Inheritance Diagram"
            },
            {
                "command": "crosswayai.openCrosswayAIViewer",
                "title": "View diagram"
            },
            {
                "command": "crosswayai.generateTableRelationsDiagram",
                "title": "Table Relations Diagram"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "crosswayai.submenu",
                    "when": "editorTextFocus",
                    "group": "navigation"
                }
            ],
            "explorer/context": [
                {
                    "submenu": "crosswayai.submenu",
                    "group": "navigation"
                }
            ],
            "crosswayai.submenu": [
                {
                    "command": "crosswayai.generateCallDiagram",
                    "when": "resourceExtname =~ /^\\.(p|P|cls|CLS|w|W)$/",
                    "group": "navigation"
                },
                {
                    "command": "crosswayai.generateImpactDiagram",
                    "when": "resourceExtname =~ /^\\.(p|P|cls|CLS|w|W|i|I)$/",
                    "group": "navigation"
                },
                {
                    "command": "crosswayai.generateIncludeDiagram",
                    "when": "resourceExtname =~ /^\\.(p|P|cls|CLS|w|W|i|I)$/",
                    "group": "navigation"
                },
                {
                    "command": "crosswayai.generateInterfaceDiagram",
                    "when": "resourceExtname =~ /^\\.(cls|CLS)$/",
                    "group": "navigation"
                },
                {   "command": "crosswayai.generateInheritanceDiagram",
                    "when": "resourceExtname =~ /^\\.(cls|CLS)$/",
                    "group": "navigation"
                },
                {
                    "command": "crosswayai.openCrosswayAIViewer",
                    "when": "resourceExtname =~ /^\\.(md|MD)$/",
                    "group": "navigation"
                },
                {
                    "command": "crosswayai.generateTableRelationsDiagram",
                    "when": "resourceExtname =~ /^\\.(df|DF)$/",
                    "group": "navigation"
                }
            ]
        }
    },
    "extensionDependencies": [
        "riversidesoftware.openedge-abl-lsp"
    ],
    "dependencies": {}
}
